# ─────────────────────────────────────────────────────────────────────────────
# ScholarRAG · .env.example
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=openai                  # openai | anthropic | local
LLM_MODEL=gpt-4o                     # gpt-4o | claude-3-5-sonnet-20241022

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5   # or intfloat/e5-large-v2
EMBEDDING_DEVICE=cpu                     # cpu | cuda | mps

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                          # leave blank for local self-hosted
QDRANT_COLLECTION=scholarrag

# ── Cohere (optional re-ranker) ───────────────────────────────────────────────
COHERE_API_KEY=
RERANKER_PROVIDER=cross-encoder          # cross-encoder | cohere
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── ArXiv Ingestion ───────────────────────────────────────────────────────────
ARXIV_MAX_RESULTS=100
ARXIV_DEFAULT_QUERY=machine learning

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=20       # candidates before reranking
TOP_K_RERANK=5           # final chunks passed to LLM
DENSE_WEIGHT=0.7         # weight for dense score in hybrid fusion
SPARSE_WEIGHT=0.3        # weight for BM25 score in hybrid fusion

# ── Quality Gate ──────────────────────────────────────────────────────────────
QUALITY_MIN_FAITHFULNESS=0.7   # RAGAS threshold
QUALITY_MIN_RELEVANCY=0.6

# ── LangSmith (observability) ─────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=scholarrag

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_LOG_LEVEL=info

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501
BACKEND_URL=http://localhost:8000
