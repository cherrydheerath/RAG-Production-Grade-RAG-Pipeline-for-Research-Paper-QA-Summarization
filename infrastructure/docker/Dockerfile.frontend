FROM python:3.11-slim

LABEL maintainer="ScholarRAG"
LABEL description="ScholarRAG Streamlit Frontend"

WORKDIR /app

RUN pip install --no-cache-dir streamlit==1.35.0 httpx==0.27.0

COPY frontend/ ./frontend/

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=10s CMD curl -f http://localhost:8501/_stcore/health || exit 1

CMD ["streamlit", "run", "frontend/streamlit_app.py", "--server.port=8501", "--server.address=0.0.0.0", "--server.headless=true"]
